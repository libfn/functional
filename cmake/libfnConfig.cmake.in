@PACKAGE_INIT@

# Full SemVer including any prerelease/build suffix that find_package cannot use.
set(libfn_VERSION_FULL "@LIBFN_PROJECT_VERSION@")

include("${CMAKE_CURRENT_LIST_DIR}/libfnTargets.cmake")

# pfn is always installed
if(TARGET libfn::pfn)
    set(libfn_pfn_FOUND TRUE)
endif()

# fn is only installed when the library was built without DISABLE_CXX23
if(TARGET libfn::fn)
    set(libfn_fn_FOUND TRUE)
endif()

check_required_components(libfn)
